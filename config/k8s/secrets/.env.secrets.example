# Copy this file to .env.secrets (gitignored) and fill in real values.
# Consumed by kustomize's secretGenerator (see ../../kustomization.yaml) to
# build the `lanai-secrets` Secret. Keys must match exactly — they become
# env var names referenced via secretKeyRef throughout the workload
# manifests.

POSTGRES_PASSWORD=
KEYCLOAK_DB_PASSWORD=
# TEMPORAL_DB_PASSWORD and PERMIFY_DB_PASSWORD just provision now-unused
# local databases (temporal/permify moved to the cluster's shared
# instances) — postgres/00-create-databases.sh is shared with
# docker-compose's local dev setup and still requires them. Any value works.
TEMPORAL_DB_PASSWORD=
CHATWOOT_DB_PASSWORD=
PERMIFY_DB_PASSWORD=
# This is the SHARED cluster Redis password, not a self-generated one —
# fetch it from wherever it's actually stored, e.g.
# kubectl get secret -n redis <name> -o jsonpath='{.data.<key>}' | base64 -d
# (find the exact secret/key name with `kubectl get secret -n redis`).
REDIS_PASSWORD=

KEYCLOAK_ADMIN_USER=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=

JWT_SECRET=
# lanai-portal's own env.ts refuses to boot in production without these
# present (non-empty) even though lanai-ai-gateway/lakehouse-ingest aren't
# deployed in current scope — they're only actually called if a feature
# that uses them is invoked, so any placeholder value works.
AI_GATEWAY_TOKEN=
LAKEHOUSE_INGEST_TOKEN=
# Same boot-required-but-currently-unenforced situation for the Dapr
# sidecar token — the shared control plane's enforcement of it is
# unconfirmed, but env.ts still requires it present.
DAPR_API_TOKEN=
# This now needs to be the shared cluster's real APISIX admin key
# (appsec-apisix-prod), not a self-generated one — there's no more
# self-hosted apisix instance to set our own key on. Ask whoever
# administers appsec-apisix-prod for it.
APISIX_ADMIN_KEY=

# Optional integrations — leave blank if unused, matching docker-compose defaults.
TWENTY_CRM_URL=
TWENTY_CRM_API_TOKEN=
CHATWOOT_URL=
CHATWOOT_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=1
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
