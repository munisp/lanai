{
  admin off
  email {$CADDY_ACME_EMAIL}
  servers {
    protocols h1 h2 h3
  }
  log {
    output stdout
    format json
    level INFO
  }
}

http:// {
  redir https://{host}{uri} permanent
}

(common_headers) {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
    -X-Powered-By
  }
}

(portal_api) {
  @api path /api/*
  handle @api {
    reverse_proxy apisix:9080 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Forwarded-Host {host}
    }
  }
}

{$LANAI_DOMAIN}, www.{$LANAI_DOMAIN} {
  import common_headers
  header {
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com; frame-src https://js.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self'"
    Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self https://js.stripe.com)"
  }
  rate_limit {
    zone main_api {
      key {remote_host}
      events 300
      window 15m
    }
  }
  import portal_api
  handle /ws/* {
    reverse_proxy lanai-portal:3001
  }
  handle {
    reverse_proxy lanai-portal:3001
  }
}

auth.{$LANAI_DOMAIN} {
  import common_headers
  header {
    X-Frame-Options "SAMEORIGIN"
  }
  rate_limit {
    zone keycloak_auth {
      key {remote_host}
      events 50
      window 15m
    }
  }
  reverse_proxy keycloak:8080 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
  }
}

api.{$LANAI_DOMAIN} {
  import common_headers
  header {
    X-Frame-Options "DENY"
  }
  rate_limit {
    zone public_api {
      key {remote_host}
      events 1000
      window 1h
    }
  }
  reverse_proxy apisix:9080 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
  }
}

# Admin and inbox are served by the same authenticated portal. Their API traffic
# still traverses APISIX/OpenAppSec; Keycloak validation and Permify decisions are
# enforced per protected procedure by the portal itself.
admin.{$LANAI_DOMAIN} {
  import common_headers
  header {
    X-Frame-Options "DENY"
    Cache-Control "no-store, no-cache, must-revalidate"
  }
  import portal_api
  handle {
    reverse_proxy lanai-portal:3001
  }
}

inbox.{$LANAI_DOMAIN} {
  import common_headers
  header {
    X-Frame-Options "SAMEORIGIN"
  }
  import portal_api
  handle {
    reverse_proxy lanai-portal:3001
  }
}

member.{$LANAI_DOMAIN} {
  import common_headers
  header {
    X-Frame-Options "SAMEORIGIN"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com; frame-src https://js.stripe.com; object-src 'none'"
  }
  rate_limit {
    zone member_api {
      key {remote_host}
      events 100
      window 15m
    }
  }
  import portal_api
  handle {
    reverse_proxy lanai-portal:3001
  }
}
