# ==============================================================================
# Lanai Portal — Environment Variables
# ==============================================================================
# Copy to .env and fill in actual values. Never commit .env to git.
# ==============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (for Drizzle ORM + MySQL2 driver per existing code)
DATABASE_URL=postgresql://openhands:PASSWORD@farmer-postgres:5432/openhands

# ── Authentication (Keycloak / Manus OAuth) ──────────────────────────────────
# OAuth server base URL (Keycloak auth server endpoint)
OAUTH_SERVER_URL=http://keycloak:8080

# OAuth application ID (registered in Keycloak)
VITE_APP_ID=lanai-portal

# JWT secret for signing session tokens (generate a strong random string)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# The openId of the first/owner admin user (set during first login)
OWNER_OPEN_ID=

# ── AI / LLM (Manus Forge / OpenAI-compatible) ─────────────────────────────
# Forge API base URL (Dapr service mesh endpoint)
BUILT_IN_FORGE_API_URL=http://dapr:3500

# Forge API key for LLM calls
BUILT_IN_FORGE_API_KEY=CHANGE_ME

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenSearch (full-text search) ───────────────────────────────────────────
OPENSEARCH_URL=http://opensearch:9200

# ── Temporal (workflow engine) ──────────────────────────────────────────────
TEMPORAL_URL=temporal:7233

# ── TigerBeetle (financial ledger) ──────────────────────────────────────────
TIGERBEETLE_ADDRESS=tigerbeetle:3001

# ── APISIX (API gateway) ───────────────────────────────────────────────────
APISIX_ADMIN_URL=http://apisix:9180

# ── Twenty CRM ──────────────────────────────────────────────────────────────
TWENTY_CRM_URL=http://twenty:3000
TWENTY_CRM_API_TOKEN=CHANGE_ME

# ── Chatwoot ────────────────────────────────────────────────────────────────
CHATWOOT_URL=http://chatwoot:3000
CHATWOOT_ACCESS_TOKEN=CHANGE_ME
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_WEBHOOK_SECRET=CHANGE_ME

# AI Bridge (Chatwoot AI microservice)
CHATWOOT_AI_BRIDGE_URL=http://localhost:5560

# ── WhatsApp ────────────────────────────────────────────────────────────────
# WhatsApp bridge runs on localhost:5555 (proxy in vite.config.ts)
# No env vars needed — proxied via /api/whatsapp

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=CHANGE_ME
FROM_EMAIL=Lanai Lifestyle <noreply@lanai.newfire.app>

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Microservices ────────────────────────────────────────────────────────
# Whale AI (port 5555) — WhatsApp bridge
# Proposals AI (port 5556)
# Intelligence AI (port 5557)
# Briefing AI (port 5558)
# Chatwoot AI Bridge (port 5560)
#
# These run as separate Docker containers on the app-net network.
# Proxy routes configured in vite.config.ts server.proxy section.

# ── Storage (Manus Forge / S3-compatible) ────────────────────────────────────
# Handled through BUILT_IN_FORGE_API_URL and BUILT_IN_FORGE_API_KEY
